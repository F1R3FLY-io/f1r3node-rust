' Methodology Diagram 01 — Layer stack of techniques.
'
' Shows the nine techniques deployed against the slashing subsystem, grouped
' by methodology family (formal-methods, randomized-search, differential-and-
' metamorphic, attack-modeling). Edges show the witness-flow between layers:
' formal methods consume Sage witnesses for corroboration; randomized layers
' feed witnesses up to formal-methods promotion; differential/metamorphic
' arbitrate between implementations.
'
' Render:
'   plantuml -tsvg docs/theory/slashing/methodology/diagrams/01-methodology-stack.puml

@startuml 01-methodology-stack
!theme plain

skinparam componentStyle rectangle
skinparam package {
  BackgroundColor<<Formal>>       #EEF2FF
  BackgroundColor<<Randomized>>   #FFF7EE
  BackgroundColor<<Differential>> #F3E5F5
  BackgroundColor<<Adversarial>>  #FFEBEE
  BackgroundColor<<Pipeline>>     #EEFAF1
  BorderColor #444444
}
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor     #333333
}
skinparam note {
  BackgroundColor #FFE0B2
  BorderColor     #E65100
}
skinparam defaultFontName "sans-serif"
skinparam defaultFontSize 11

title Methodology layer stack — nine techniques across four families

legend right
  | Color | Family |
  |<#EEF2FF>| Formal methods (Rocq, TLA⁺, Kani) |
  |<#FFF7EE>| Randomized (proptest, Hypothesis, libFuzzer, Loom) |
  |<#F3E5F5>| Differential & metamorphic |
  |<#FFEBEE>| Adversarial / attack modeling |
  |<#EEFAF1>| Pipeline / classification |
  | Edge | Semantics |
  |<color:#2E7D32>green| Promotion to mechanized theorem |
  |<color:#1565C0>blue|  Corroboration / cross-check |
  |<color:#C62828>red|   Refutation / counterexample |
endlegend

' === Layer 1: Adversarial input ===
package "Adversarial input layer" <<Adversarial>> {
  component "STRIDE pass\n(threat model §2.1)"          as STRIDE
  component "Attack trees\n(threat model §2.2)"          as Trees
  component "Damage optimizer\n(Sage)"                   as Damage
  component "Deep-threat model\n(Sage; Pareto frontier)" as DeepThreat
}

' === Layer 2: Formal methods (mechanized) ===
package "Formal-methods layer (mechanized)" <<Formal>> {
  component "Rocq\n(theorems; unbounded)"      as Rocq
  component "TLA⁺ + TLC\n(exhaustive bounded)" as TLC
  component "TLA⁺ + Apalache\n(SMT-symbolic)\n[planned; not yet\n exercised]"  as Apalache
  component "Kani\n(symbolic Rust)"            as Kani
  component "Sage\n(exact finite modeling)"    as Sage
}

' === Layer 3: Randomized search ===
package "Randomized-search layer" <<Randomized>> {
  component "proptest\n(in-Rust, sub-second)"         as PropTest
  component "Hypothesis\n(stateful, shrinking)"        as Hypothesis
  component "libFuzzer / cargo-fuzz\n(coverage-guided)" as LibFuzzer
  component "Loom\n(concurrency interleavings)"        as Loom
}

' === Layer 4: Differential / metamorphic ===
package "Differential & metamorphic layer" <<Differential>> {
  component "Triple-bisim driver\n(harness ↔ oracle ↔ production)" as Triple
  component "Differential Rust-vs-Scala\n(corpus generator)"       as Diff
  component "Metamorphic relations\n(permutation, idempotence, …)" as Meta
}

' === Layer 5: Promotion pipeline ===
package "Promotion pipeline" <<Pipeline>> {
  component "Traceability ledger\n(8 statuses)"           as Ledger
  component "Threat-model classifier\n(6 classes)"        as Classifier
  component "Witness rule gate\n(see pipeline/01)"         as WitnessGate
  component "Persistent corpora\n(corpus_generator + fuzz/corpus)" as Corpus
}

' === Edges: witness flow ===

' Adversarial layer feeds Sage and Hypothesis with candidate strategies
STRIDE        --[#1565C0]--> Sage         : threat seeds
Trees         --[#1565C0]--> Sage         : leaf coverage
Damage        --[#1565C0]--> Sage         : objective scores
DeepThreat    --[#1565C0]--> Hypothesis   : multi-step traces

' Sage feeds randomized layer and TLA⁺ with witnesses
Sage          --[#C62828]--> WitnessGate  : witness
Sage          --[#1565C0]--> TLC          : finite test cases
Sage          --[#1565C0]--> Apalache     : symbolic bounds
Sage          --[#1565C0]--> Hypothesis   : seed scenarios

' Randomized feeds witnesses to the gate
PropTest      --[#C62828]--> WitnessGate  : witness
Hypothesis    --[#C62828]--> WitnessGate  : witness
LibFuzzer     --[#C62828]--> WitnessGate  : crash / counterexample
Loom          --[#C62828]--> WitnessGate  : schedule witness
Kani          --[#C62828]--> WitnessGate  : symbolic CE

' Differential layer arbitrates among implementations
Triple        --[#1565C0]--> Ledger       : divergence reports
Diff          --[#1565C0]--> Ledger       : Rust-vs-Scala diffs
Meta          --[#1565C0]--> PropTest     : transformation properties

' Witness gate routes through classifier and into ledger
WitnessGate   --> Classifier              : classify (6)
Classifier    --> Ledger                  : status (8)
Ledger        --> Corpus                  : persist

' Ledger promotes to formal methods
Ledger        --[#2E7D32]--> Rocq         : promote theorem
Ledger        --[#2E7D32]--> TLC          : promote invariant
Ledger        --[#2E7D32]--> Kani         : promote per-fn proof

' Formal methods corroborate each other
Rocq          --[#1565C0]--> TLC          : finite-bound check
TLC           --[#1565C0]--> Apalache     : widen domain

note bottom of WitnessGate
  Witness rule (philosophy §4): a generated witness is *not* a
  Rust vulnerability unless it reproduces on the production
  Rust path or contradicts a production-path invariant.
end note

@enduml
