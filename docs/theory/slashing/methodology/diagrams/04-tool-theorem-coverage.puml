' Methodology Diagram 04 — Tool ↔ Theorem coverage map (component).
'
' Maps each load-bearing theorem to the tools that corroborate it.
' Solid edges = primary mechanization; dashed edges = corroboration.
' The diagram makes the methodology's evidence-stacking visible at a glance:
' every theorem has multiple incident edges from distinct tool families.
'
' Render:
'   plantuml -tsvg docs/theory/slashing/methodology/diagrams/04-tool-theorem-coverage.puml

@startuml 04-tool-theorem-coverage
!theme plain

skinparam componentStyle rectangle
skinparam package {
  BackgroundColor<<Formal>>      #EEF2FF
  BackgroundColor<<Randomized>>  #FFF7EE
  BackgroundColor<<Theorem>>     #EEFAF1
  BorderColor #444444
}
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor     #333333
}
skinparam defaultFontName "sans-serif"
skinparam defaultFontSize 10

title Tool ↔ Theorem coverage — every load-bearing theorem is multi-corroborated

legend right
  | Edge | Semantics |
  |<color:#2E7D32>green solid|  Primary mechanized arm |
  |<color:#1565C0>blue dashed| Randomized / corroborating arm |
  |<color:#6A1B9A>purple solid|  Differential / metamorphic arm |
endlegend

' === Tools (clustered by family) ===

package "Formal-methods tools" <<Formal>> {
  component "Rocq"      as Rocq
  component "TLA⁺ + TLC" as TLC
  component "Kani"      as Kani
  component "Sage"      as Sage
  note right of TLC
    Apalache (symbolic TLA⁺)
    is the prescribed fallthrough
    when TLC's bound is too tight,
    but is not yet exercised
    against any finding — omitted
    from this coverage diagram.
  end note
}

package "Randomized tools" <<Randomized>> {
  component "proptest"    as PropTest
  component "Hypothesis"  as Hypothesis
  component "libFuzzer"   as LibFuzzer
  component "Loom"        as Loom
  component "Triple-bisim driver" as Triple
}

' === Headline theorems (load-bearing) ===

package "Load-bearing theorems" <<Theorem>> {
  component "T-1  Detection soundness"           as T1
  component "T-2  Detection completeness"        as T2
  component "T-4  Record uniqueness"              as T4
  component "T-7  Slash zeros bond"               as T7
  component "T-9.2  Atomic tracker (Bug #2)"     as T92
  component "T-9.8  Slash authorization (Bug #12)"  as T98
  component "T-9.10 Withdraw safety (Bug #10)"    as T910
  component "T-9.11 Detector totality (Bug #11)" as T911
  component "T-9.15 Checked arithmetic (Bug #15)" as T915
  component "T-9.16 Justification projection (Bug #16)" as T916
  component "T-11  Closure depth bound"           as T11
  component "T-12  BFT quorum preservation"       as T12
  component "T-15  Bisimilarity Rust ≈ Scala"    as T15
  component "T-Auth System auth-token guard"      as TAuth
  component "T-Idem Slash idempotence"            as TIdem
}

