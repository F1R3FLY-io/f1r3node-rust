' No double-spend — every state, transition, and guarded condition of
' consume_linear_atom on the LINEAR zone Δ, contrasted with reuse_unrestricted on
' the UNRESTRICTED zone Γ. Linear witnesses deplete (spent once; a second/absent
' consume returns None); unrestricted resources persist (idempotent reuse).
'
' Source of truth for Figure 6 in docs/theory/cost-accounting-linear-logic.md.
' Palette:  has-witness=green #C8E6C9 · exhausted=blue #BBDEFB · rejected(None)=red #EF9A9A
'           reusable(Γ)=indigo #C5CAE9
'   arrows: consume/spend=red #C62828 · reuse=indigo #3949AB
' Render:  plantuml -tsvg docs/theory/diagrams/no-double-spend-statechart.puml

@startuml no-double-spend-statechart
!theme plain
skinparam state {
  BorderColor              #333333
  BackgroundColor<<has>>   #C8E6C9
  BackgroundColor<<empty>> #BBDEFB
  BackgroundColor<<rej>>   #EF9A9A
  BackgroundColor<<reuse>> #C5CAE9
  ArrowColor               #444444
}
title No double-spend — consume_linear_atom (linear Δ) vs reuse_unrestricted (unrestricted Γ)

state "Linear zone Δ  ·  single-use" as LIN {
  state "Has a\nΔ = [a]"     as HasA  <<has>>
  state "Has a, a\nΔ = [a, a]" as HasAA <<has>>
  state "Exhausted\nΔ = [ ]"  as Empty <<empty>>
  state "Rejected\n(None)"    as Rej   <<rej>>

  [*] --> HasA  : Δ = [a]
  [*] --> HasAA : Δ = [a, a]
  HasAA -[#C62828]-> HasA  : consume a  [a ∈ Δ]  / Some [a]\n(ll_double_spend_requires_duplicate_witness)
  HasA  -[#C62828]-> Empty : consume a  [a ∈ Δ]  / Some [ ]\n(ll_consume_linear_once_atom_exhausts)
  HasA  -[#C62828]-> Rej   : consume b  [b ∉ Δ]  / None
  Empty -[#C62828]-> Rej   : consume a  [a ∉ Δ]  / None\n(ll_no_double_spend_single_witness)
  Empty --> [*]
  Rej   --> [*]
}

state "Unrestricted zone Γ  ·  reusable" as UNR {
  state "Has f\nf ∈ Γ" as HasF <<reuse>>
  [*] --> HasF
  HasF -[#3949AB]-> HasF : use f  / Γ unchanged\n(ll_unrestricted_can_be_reused — idempotent)
}

note bottom of LIN
  Linear witnesses deplete — spent exactly once; a second
  consume, or a consume of an absent atom, returns None.
  cut: consume a (a :: Δ) = Some Δ  (ll_linear_cut_consumes_cut_witness)
end note
note bottom of UNR
  Unrestricted ( !-marked ) resources persist —
  reuse_unrestricted γ = γ, usable any number of times.
end note
@enduml
