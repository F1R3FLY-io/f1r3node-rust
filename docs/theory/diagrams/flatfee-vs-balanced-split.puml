' Flat fee (transfer) vs balanced cost split (burn) — the FEE is one client token
' per admitted deploy, drawn ONCE by FlatFeeApportionment and carved as a
' CONSERVING transfer Σ⟦c⟧ −= fee then F_v += fee (not a mint). The COST Δ of a
' multi-sig deploy is debited EQUALLY across each cosigner's Σ⟦Ground(pkᵢ)⟧ via
' DefaultApportionment — a BURN. cost ≠ fee; flat ≠ balanced.
'
' Source of truth: docs/theory/cost-accounting-spec-alignment-audit.md
'                  (FlatFeeApportionment / DefaultApportionment; acceptance.rs:108-156).
' Palette:  client/cosigner supply pool=mint #C8E6C9 · validator fee channel F_v=mint #C8E6C9
'           control/apportionment=amber #FFECB3
'   arrows: debit/cost out (BURN/carve)=red #C62828 · conserve/credit in=green #2E7D32
' Render:  plantuml -tsvg docs/theory/diagrams/flatfee-vs-balanced-split.puml

@startuml flatfee-vs-balanced-split
!theme plain
skinparam defaultFontName "sans-serif"
skinparam componentStyle rectangle
skinparam shadowing false
skinparam ArrowFontSize 11
skinparam package {
  BorderColor #444444
}
skinparam component {
  BorderColor #333333
}
skinparam NoteBackgroundColor #FFF8E1
skinparam NoteBorderColor     #666666
title FEE = transfer (conserving, flat-per-deploy)  ·  COST = burn (balanced-per-cosigner)

package "LEFT — FLAT FeeExtract (F-C / F-D)" <<#C8E6C9>> {
  component "FlatFeeApportionment\n— ONE token per ADMITTED deploy" <<#FFECB3>> as FFA
  component "Σ⟦c⟧  client supply pool\n(combined pool first,\nelse canonical-first component)" <<#C8E6C9>> as CPOOL
  component "F_v  validator fee channel" <<#C8E6C9>> as FV

  FFA  -[#C62828]-> CPOOL : draw ONE token\nΣ⟦c⟧ −= fee   (carve)
  CPOOL -[#2E7D32]-> FV   : F_v += fee   (credit)
  note bottom of FV #E8F5E9
    CONSERVING TRANSFER, not a mint:
    Σ⟦c⟧ debited == F_v credited.
    Flat — exactly one token per deploy,
    independent of cosigner count.
  end note
}

package "RIGHT — Balanced cost split (P8)" <<#C5CAE9>> {
  component "DefaultApportionment\n— split cost Δ EQUALLY per cosigner" <<#FFECB3>> as DA
  component "Σ⟦Ground(pk₁)⟧\ncosigner 1 pool" <<#C8E6C9>> as P1
  component "Σ⟦Ground(pk₂)⟧\ncosigner 2 pool" <<#C8E6C9>> as P2
  component "Σ⟦Ground(pk₃)⟧\ncosigner 3 pool" <<#C8E6C9>> as P3

  DA -[#C62828]-> P1 : Δ / n   (BURN)
  DA -[#C62828]-> P2 : Δ / n   (BURN)
  DA -[#C62828]-> P3 : Δ / n   (BURN)
  note bottom of P2 #FFEBEE
    BURN, balanced: the deploy COST Δ is
    debited in EQUAL weight from each
    cosigner's own Σ⟦Ground(pkᵢ)⟧.
    Nothing is credited anywhere.
  end note
}

note as DIVIDER #FFF8E1
  FEE = transfer (conserving, flat-per-deploy)  ·  COST = burn (balanced-per-cosigner).
  cost ≠ fee ;  flat ≠ balanced.   The fee is computed AFTER the cost debit, against
  the post-cost residual (admit only if Σ⟦c⟧ ≥ cost + fee).
end note
FV   .. DIVIDER
DIVIDER .. P2

legend bottom
  |= color |= meaning |
  |<#C8E6C9>| supply pool Σ⟦·⟧ / validator fee channel F_v (accounting) |
  |<#FFECB3>| apportionment policy (control) |
  |<#C62828>| debit / cost-out — carve (LEFT) or BURN (RIGHT) |
  |<#2E7D32>| conserving credit into F_v (LEFT) |
endlegend

@enduml
