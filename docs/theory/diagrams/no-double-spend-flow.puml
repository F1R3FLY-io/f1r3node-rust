' No double-spend — flowchart of consume_linear_atom on the linear zone Δ,
' contrasted with reuse_unrestricted on the unrestricted zone Γ. Double-spend is
' prevented because consuming an already-spent (absent) atom returns None.
'
' Source of truth for Figure 6 in docs/theory/cost-accounting-linear-logic.md.
' Palette:  spent/Some=green #C8E6C9 · rejected/None=red #EF9A9A · reusable Γ=indigo #C5CAE9
'           decisions=amber #FFE082 · linear-zone input=orange #FFE0B2
' Render:  plantuml -tsvg docs/theory/diagrams/no-double-spend-flow.puml

@startuml no-double-spend-flow
!theme plain
skinparam defaultFontName "sans-serif"
skinparam ArrowColor                     #444444
skinparam ActivityBorderColor            #333333
skinparam ActivityBackgroundColor        #FFFFFF
skinparam ActivityDiamondBackgroundColor #FFE082
skinparam ActivityDiamondBorderColor     #333333
skinparam NoteBackgroundColor            #FFF8E1
skinparam NoteBorderColor                #666666
title No double-spend — consume_linear_atom (linear Δ) vs reuse_unrestricted (unrestricted Γ)

start
:a resource is presented for use;
if (which zone holds it?) then (linear Δ — single-use)
  :consume_linear_atom(a, Δ); <<#FFE0B2>>
  if (is a present in Δ?) then (yes · a ∈ Δ)
    :remove the first matching a; <<#C8E6C9>>
    :return Some Δ′\n— witness a spent exactly once; <<#C8E6C9>>
    note right
      [a]    → one spend, then a is absent
      [a, a] → two spends, then absent
      cut: consume a (a :: Δ) = Some Δ
      ll_consume_linear_once_atom_exhausts
      ll_double_spend_requires_duplicate_witness
      ll_linear_cut_consumes_cut_witness
    end note
  else (no · a ∉ Δ — already spent / never held)
    :return None; <<#EF9A9A>>
    :spend REJECTED — no double-spend; <<#EF9A9A>>
    note right
      a second spend of an exhausted atom,
      or any absent atom, fails
      ll_no_double_spend_single_witness
    end note
  endif
else (unrestricted Γ — reusable)
  :use f   (f ∈ Γ); <<#C5CAE9>>
  :reuse_unrestricted γ = γ\n— Γ unchanged, usable any number of times; <<#C5CAE9>>
  note right
    ! -marked resources persist; reuse is idempotent
    ll_unrestricted_can_be_reused
  end note
endif
stop
@enduml
