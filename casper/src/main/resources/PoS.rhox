// Rholang macro parameters:
// minimumBond - the minimum bond allowed by the PoS
// maximumBond - the maximum bond allowed by PoS
// initialBonds - the initial bonds map
// epochLength - the length of the validation epoch in blocks
// quarantineLength - the length of the quarantine time in blocks
// numberOfActiveValidators - max number of active validator in a shard
// posMultiSigPublicKeys - public keys
// posMultiSigQuorum - how many confirmations are necessary to use multi-sig vault
// initialPhlogiston - phlogiston minted into a validator's draw wallet @W_v when it first bonds (Cost-Accounted Rho, spec Appendix B; DR-13)
// epochPhlogiston - phlogiston minted into each active validator's draw wallet @W_v at every epoch boundary (Cost-Accounted Rho, spec Appendix B/§4.7; DR-13)
/*

Life cycle in POS

POS internal state:
"allBonds"        : Map[Validator, bonds],
"activeValidators": Set[Validator],
"withdrawers"     : Map[Validator, (bonds, quantinue)],
"committedRewards" : Map[Validator, rewards],
"pendingWithdrawers": Map[Validator, quantinue]

**There are two vaults `posVault` and `coopMultiSigVault` while pos contract have no controll on `coopMultiSigVault` but `posVault`**

Several crucial calculate points:

## UserDeploy

* precharge -> user transfer the precharge funding to posVault
* refund -> posVault transfer the refund amount back to userVault

## Bonding

User transfer the bonding amount directly to posVault. `allBonds` would update with {Validator: bondAmount}.

## Withdraw(Unbond)

`pendingWithdrawers` would update with {Validator: quantinue}


## EpochChange(CloseBlock)

1. Calculate all the validator current epoch rewards based on active validator bonding proportion
2. Accumulate `committedRewards` with the result of step 1
3. Update `withdrawers` according to `allBonds` and `pendingWithdrawers` when pendingWithdrawers is not empty, remove the validator in `allBonds`
4. When the block number reaches the quantinue of `withdrawers` , transfer the corresponding bonds+ rewards to the corresponding validator from posVault.
5. update `pendingWithdrawers` to empty Map {}.
6. Pick new `activeValidators`


## Slashing
1. Transfer the bonding amount of the slashed validator based on `allBonds` from posVault to coopMultiSigVault.
2. Set the bonding amount in `allBonds` of the slashed validator to 0
3. remove the slashed validator in `activeValidators`

*/

/*
 The table below describes the required computations and their dependencies

 No. | Dependency | Computation method | Result
 ----+------------+--------------------+-----------------------------------------------------------------------------------------------------------------------------------------------------
 1.  |            | given              | sk = a9585a0687761139ab3587a4938fb5ab9fcba675c79fefba889859674046d4a5
 2.  |            | given              | timestamp = 1559156420651
 3.  |            | lastNonce          | nonce = 9223372036854775807
 4.  | 1,         | secp256k1          | pk = 047b43d6548b72813b89ac1b9f9ca67624a8b372feedd71d4e2da036384a3e1236812227e524e6f237cde5f80dbb921cac12e6500791e9a9ed1254a745a816fe1f
 5.  | 2, 4, 3,   | registry           | value = (1559156420651, 047b43d6548b72813b89ac1b9f9ca67624a8b372feedd71d4e2da036384a3e1236812227e524e6f237cde5f80dbb921cac12e6500791e9a9ed1254a745a816fe1f, 9223372036854775807)
 6.  | 5,         | protobuf           | toSign = 2a65aa01620a092a0710d6c0b7cfe05a0a462a44ca0141047b43d6548b72813b89ac1b9f9ca67624a8b372feedd71d4e2da036384a3e1236812227e524e6f237cde5f80dbb921cac12e6500791e9a9ed1254a745a816fe1f0a0d2a0b10feffffffffffffffff01
 7.  | 6, 1,      | secp256k1          | sig = 3045022100cd1a32e04e21deb1bb3cd108cb0a3ab1357495f6ad99dfeb08eb17eaa082d388022015a9c5f9cd3b489a1fe3e359dbfe791ddd7d66e8a9a1dfb4978c980128c53f69
 8.  | 4,         | registry           | uri = rho:id:m3xk7h8r54dtqtwsrnxqzhe81baswey66nzw6m533nyd45ptyoybqr
 ----+------------+--------------------+-----------------------------------------------------------------------------------------------------------------------------------------------------
*/

new PoS,
    registryLookup(`rho:registry:lookup`),
    vaultAddressOps(`rho:vault:address`),
    systemVaultCh, listOpsCh,
    getUser,
    pickActiveValidators,
    runMVar,
    fst,
    deposit, distributeRewards,
    perActiveValidatorPosVaultsCh,
    rs(`rho:registry:insertSigned:secp256k1`),
    posId(`rho:system:deployerId`),
    PendingRewards, MergeIntMaps, treeHashMapCh,
    sysAuthTokenOps(`sys:authToken:ops`),
    multiSigSystemVaultCh, coopVaultCh, makeMintCh,
    uriOut, sumFromPair
in {
  // Simultaneously retrieves SystemVault, ListOps, TreeHashMap, MultiSigSystemVault,
  // and MakeMint contracts from the registry. MakeMint funds the per-validator
  // phlogiston draw wallet @W_v in `mintPhlogiston` (Cost-Accounted Rho, DR-13).
  registryLookup!(`rho:vault:system`, *systemVaultCh) |
  registryLookup!(`rho:lang:listOps`, *listOpsCh) |
  registryLookup!(`rho:lang:treeHashMap`, *treeHashMapCh) |
  registryLookup!(`rho:vault:multiSig`, *multiSigSystemVaultCh) |
  registryLookup!(`rho:system:makeMint`, *makeMintCh) |
  for (@(_, SystemVault)         <- systemVaultCh &
       @(_, ListOps)          <- listOpsCh &
       TreeHashMap            <- treeHashMapCh &
       @(_, MultiSigSystemVault) <- multiSigSystemVaultCh &
       @(_, MakeMint)         <- makeMintCh) {
    new posDeployerVaultAddressCh, posDeployerAuthKeyCh, posDeployerVaultCh, posVaultCh,
        initialActiveCh, pendingRewardsMapCh, createUnfVault, moveInitialBondCh, posAuthKeyCh
    in {

      // Creates the auth key and System vault associated with the PoS contract.
      new posPkCh in {
        @SystemVault!("deployerAuthKey", *posId, *posDeployerAuthKeyCh) |
        getUser!(*posId, *posPkCh) |
        for (@posPk <- posPkCh) {
          vaultAddressOps!("fromPublicKey", posPk, *posDeployerVaultAddressCh) |
          // Creates Coop multisig vault for slashed funds.
          // Either (false, errorMsg) or (true, (multiSigVault, vaultAddress, systemVault)) are returned on coopVaultCh.
          @MultiSigSystemVault!(
            "create",
            $$posMultiSigPublicKeys$$,
            [],
            $$posMultiSigQuorum$$,
            *coopVaultCh
          )
        }
      } |
      // ret: the return channel of the create
      // pubKey: the pubkey which control the unforgeable name
      contract createUnfVault(ret, @pubkey) = {
        new unf, unfAddrRet, createRetCh, pubKeyChainUnfVault, unfVaultHandle, stdout(`rho:io:stdout`) in {
          vaultAddressOps!("fromUnforgeable", *unf, *unfAddrRet) |
          for (@unfAddr <- unfAddrRet){
            @SystemVault!("findOrCreate", unfAddr, *createRetCh) |
            for (@(true, vault) <- createRetCh){
              contract unfVaultHandle(@"transfer", @targetAddress, @amount, deployerID, transferRet) = {
                new deployerPubKeyBytesCh, DeployerIdOps(`rho:system:deployerId:ops`) in {
                  DeployerIdOps!("pubKeyBytes", *deployerID, *deployerPubKeyBytesCh) |
                  for (@deployerPubKeyBytes <- deployerPubKeyBytesCh) {
                    if (deployerPubKeyBytes ==  pubkey.hexToBytes()){
                      new unfAuthKeyCh in {
                        @SystemVault!("unforgeableAuthKey", *unf, *unfAuthKeyCh) |
                        for (@unfAuthKey <- unfAuthKeyCh){
                          @vault!("transfer", targetAddress, amount, unfAuthKey, *transferRet)
                        }
                      }
                    } else {
                      transferRet!((false, "You have not permission to transfer."))
                    }
                  }
                }
              } |
              ret!((*unf, unfAddr, vault ,*unfVaultHandle))
            }
          }
        }
      }|
      createUnfVault!(*posVaultCh, "$$posPubKey$$") |
      for (@(posVaultUnf, posVaultAddr, posVault, humanControlHandle) <- posVaultCh){
      @SystemVault!("unforgeableAuthKey", posVaultUnf, *posAuthKeyCh) |
      for (@posDeployerVaultAddress <- posDeployerVaultAddressCh;
           @posDeployerAuthKey    <- posDeployerAuthKeyCh;
           @posAuthKey <- posAuthKeyCh)  {
        for (@(true, (coopMultiVault, coopMultiVaultAddr, coopVaultHd)) <<- coopVaultCh) {
          // Creates PoS System vault with sum of initial bonds.
          new bondSumCh in {
            @ListOps!("fold", $$initialBonds$$.toList(), 0, *sumFromPair, *bondSumCh) |
            for (@bondSum <- bondSumCh) {
              @SystemVault!("createWithBalance", posDeployerVaultAddress, bondSum, *posDeployerVaultCh)|
              for (@(true, posDeployerVault)  <- posDeployerVaultCh) {
                // move all the fund from deployer addr to POS unforgeable vault
                @posDeployerVault!("transfer", posVaultAddr, bondSum, posDeployerAuthKey, *moveInitialBondCh)
              }
            }
          } |
          // Selects the initial active validators.
          pickActiveValidators!($$initialBonds$$.toList(), *initialActiveCh) |
          for (@initialActive     <- initialActiveCh;
               @(true, _) <- moveInitialBondCh) {
            new stateCh, pendingRewardsInitializedCh, rewardsInfo, calTotalActiveBonds, calTotalBonds,
                accumulateSndNum, accumulateFstOfSndArg, accumulateItemInState, walletTag,
                mintPhlogistonToValidators in {
              // `walletTag` is a fresh genesis-scoped unforgeable name (a sibling
              // of `posDeployStateTag` in kind: a content-addressing tag), used
              // ONLY to build the per-validator phlogiston DRAW wallet channel
              // @W_v := @(*walletTag, validatorPk) (Cost-Accounted Rho, spec
              // Appendix B eq:38; DR-13). It is allocated here in the PoS-state
              // scope (rather than the narrower `posDeployStateTag` block) so it is
              // in scope for every site that references @W_v: the bond-time VB
              // install (`bond`), `mintPhlogiston`, and the genesis bonded-set VB
              // install — all of which live across sibling contract blocks. See the
              // full unforgeability/injectivity/merge-safety rationale at the
              // `mintPhlogiston`/VB definitions below.
              //
              // DR-13 (CRITICAL): @W_v (the validator's DRAW channel) is DISTINCT
              // from the SUPPLY POOL Σ⟦v⟧ = from_sig(Ground(pk)) that the WD-D2
              // acceptance gate reads. Rholang cannot name Σ⟦v⟧ (no bytes→GPrivate
              // surface primitive — the unforgeability mechanism), so the Σ⟦v⟧
              // balance write is a Rust `produce_balance` co-located in the same
              // sysAuthToken-bearing system deploy; it is NOT written in Rholang.
              // Initializes PoS state structure.
              stateCh!({
                // Map[PublicKey, Int] - each validator stake
                "allBonds"        : $$initialBonds$$,
                // Set[PublicKey]     - the active validators
                "activeValidators": initialActive,
                // Map[PublicKey, (Int, Int)] - The validators who issued a withdraw request , finished validating jobs and not active.
                //                              When the validator reachs the quantinue length, it would be removed in the map and
                //                              pos would transfer back all the original bond and rewards back to validator vault.
                //                              Value(Int, Int) represents (original bond + reward, quantinue length)
                "withdrawers"     : {},
                // Map[PublicKey, Int]
                "committedRewards" : {},
                // Map[PublicKey, Int] - the validators wishing to withdraw and the block number when their quarantine ends
                "pendingWithdrawers": {},
                "randomImages"    : {},
                "randomNumbers"   : {},
                // Set[(PublicKey, Int)] - per-validator-per-epoch mint ledger
                //   (Cost-Accounted Rho, Stage B Decision 3; DR-13). An entry
                //   (pk, epochIndex) records that `pk` was already minted its
                //   phlogiston for `epochIndex = blockNumber / epochLength`. The
                //   closeBlock mint fold skips any (pk, epochIndex) already
                //   present, so a replayed / multi-parent-duplicated epoch mint
                //   is a no-op on BOTH @W_v and Σ⟦v⟧ (idempotency). Genesis-init
                //   empty; the genesis bonded set is funded on block 1 via the
                //   non-epoch (epochIndex=0) mint path.
                "mintedEpochs"     : Set(),
                // Set[PublicKey] - validators whose minting is halted (the
                //   Cost-Accounted Rho slash effect, spec Appendix B / DR-3).
                //   The closeBlock mint fold skips any pk in this set across ALL
                //   epochs (the cross-epoch halt). Stage C's `slash` inserts pk
                //   here (and zeros Σ⟦v⟧ + drains @W_v); `redeemSlashed` removes
                //   it (and lets the normal next-epoch mint re-fund). Genesis-init
                //   empty (no validator starts halted).
                "mintingHalted"    : Set(),
              }) |
              contract rewardsInfo(retCh) = {
                new posBalanceCh, totalActiveBondCh, totalBondCh, totalWithdrawCh, committedRewardsCh in {
                  @posVault!("balance", *posBalanceCh) |
                  accumulateItemInState!(*totalBondCh, "allBonds", *accumulateSndNum) |
                  calTotalActiveBonds!(*totalActiveBondCh) |
                  accumulateItemInState!(*totalWithdrawCh, "withdrawers", *accumulateFstOfSndArg) |
                  accumulateItemInState!(*committedRewardsCh, "committedRewards", *accumulateSndNum) |
                  for (@posBalance <- posBalanceCh; @totalBond <- totalBondCh; @activeBonds <- totalActiveBondCh;
                       @totalWithdraw <- totalWithdrawCh; @totalCommittedRewards <- committedRewardsCh){
                    for (@state <<- stateCh) {
                      retCh!((posBalance , totalBond , activeBonds, totalWithdraw, totalCommittedRewards, state.get("allBonds"), state.get("activeValidators")))
                    }
                  }
                }
              } |
              contract calTotalActiveBonds(returnCh) = {
                new computeSum in {
                  for (@state <<- stateCh){
                    @ListOps!("fold", state.get("allBonds").toList(), 0, *computeSum, *returnCh) |
                    contract computeSum(@(pk, bondAmount), @acc, resultCh) = {
                      if (state.get("activeValidators").contains(pk)){
                        resultCh!(acc + bondAmount)
                      } else {
                        resultCh!(acc)
                      }
                    }
                  }
                }
              } |
              contract accumulateSndNum(@(_, amount), @acc, resultCh) = {
                resultCh!(acc + amount)
              } |
              contract accumulateFstOfSndArg(@(_, (amount, _)), @acc, resultCh) = {
                resultCh!(acc + amount)
              } |
              contract accumulateItemInState(returnCh, @stateKey, accumulateAlgo) = {
                for (@state <<- stateCh){
                  @ListOps!("fold", state.get(stateKey).toList(), 0, *accumulateAlgo, *returnCh)
                }
              }|
              contract PoS(@"getCurrentEpochRewards", returnCh) = {
                new rewardCh, computeReward in {
                  rewardsInfo!(*rewardCh)|
                  for (@(posBalance, totalBond, activeBonds, totalWithdraw, totalCommittedRewards, bondsMap, activeValidatorsSet) <- rewardCh){
                    @ListOps!("fold", bondsMap.toList(), {}, *computeReward, *returnCh) |
                    contract computeReward(@(pk, bonds), @acc,  outCh) = {
                      //  someAmount / minimumBond to reduce the possibility on overflow long
                      if (activeValidatorsSet.contains(pk)){
                        outCh!(acc.set(pk, (posBalance - totalBond - totalWithdraw - totalCommittedRewards) * (bonds / $$minimumBond$$) / (activeBonds / $$minimumBond$$)))
                      } else {
                        outCh!(acc.set(pk, 0))
                      }
                    }
                  }
                }
              } |
              contract PoS(@"getRewards", returnCh) = {
                new currentEpochRewardCh, accumulateReward in {
                  for (@state <<- stateCh) {
                    PoS!("getCurrentEpochRewards", *currentEpochRewardCh)|
                    for (@currentEpochReward <- currentEpochRewardCh) {
                      @ListOps!("fold", currentEpochReward.toList(), state.get("committedRewards"), *accumulateReward, *returnCh) |
                      contract accumulateReward(@(pk, reward), @acc, outCh) = {
                        outCh!(acc.set(pk, acc.getOrElse(pk, 0) + reward))
                      }
                    }
                  }
                }
              } |
              // Peeks at bonds map.
              contract PoS(@"getBonds", returnCh) = {
                for (@state <<- stateCh) {
                  returnCh!(state.get("allBonds"))
                }
              } |
              // Peeks at active validator list.
              contract PoS(@"getActiveValidators", returnCh) = {
                for (@state <<- stateCh) {
                  returnCh!(state.get("activeValidators"))
                }
              } |
              // Peeks at active validator list.
              contract PoS(@"getWithdrawers", returnCh) = {
                for (@state <<- stateCh) {
                  returnCh!(state.get("withdrawers"))
                }
              } |
              contract PoS(@"getPendingWithdrawer", returnCh) = {
                for (@state <<- stateCh) {
                  returnCh!(state.get("pendingWithdrawers"))
                }
              } |
              // Exposes Coop multisig vault on returnCh.
              contract PoS(@"getCoopVault", returnCh) = {
                for (@(_, coopVault) <<- coopVaultCh) {
                  returnCh!((coopMultiVault, coopMultiVaultAddr, coopVaultHd))
                }
              } |
              // Exposes initial PoS vault on returnCh.
              contract PoS(@"getInitialPosVault", returnCh) = {
                returnCh!((posVaultAddr, posVault))
              } |
              // Exposes epochLength parameter to PoSTest.
              contract PoS(@"getEpochLength", returnCh) = {
                returnCh!($$epochLength$$)
              } |
              // Exposes quarantineLength parameter to PoSTest.
              contract PoS(@"getQuarantineLength", returnCh) = {
                returnCh!($$quarantineLength$$)
              } |
              contract PoS(@"posVaultTransfer", @targetAddress, @amount, @deployerID, @transferRet) = {
                // human transfer would just use this method
                @humanControlHandle!("transfer", targetAddress, amount, deployerID, transferRet)
              } |
              // Public method allowing users to bond and become validators.
              contract PoS(@"bond", @deployerId, @amount, returnCh) = {
                new userCh, depositCh,
                    processCh
                in {
                  runMVar!(*stateCh, *processCh, *returnCh) |
                  getUser!(deployerId, *userCh) |
                  for (@state, resultCh <- processCh &
                       @userPk          <- userCh) {
                    if (state.get("allBonds").contains(userPk)) {
                      resultCh!(state, (false, "Public key is already bonded."))
                    } else if (amount <= 0) {
                      // Bug #5 fix: explicit positive-stake assertion. The
                      // Rocq invariant `active_implies_bonded` (T-9.5,
                      // BugFixStakeZero.v:36) requires every active
                      // validator to have a strictly positive bond. The
                      // earlier `amount < minimumBond` check covers this
                      // when minimumBond ≥ 1, but a defensive zero-stake
                      // gate makes the invariant explicit and independent
                      // of genesis configuration. See
                      // design/09-bug-fixes-and-rationale.md §9.6 (option a).
                      resultCh!(state, (false, "Bond amount must be positive."))
                    } else if (amount < $$minimumBond$$) {
                      resultCh!(state, (false, "Bond is less than minimum!"))
                    } else if (amount > $$maximumBond$$) {
                      resultCh!(state, (false, "Bond is greater than maximum!"))
                    } else {
                      // Transfers user's bond amount to the PoS vault.
                      deposit!(deployerId, amount, posVaultAddr, *depositCh) |
                      for (@depositResult <- depositCh) {
                        match depositResult {
                          // If deposit is successful, the user becomes a bonded validator.
                          (true, _) => {
                            // Install the spec's persistent validator bootstrap VB
                            // (Cost-Accounted Rho, spec Appendix B eq:39; DR-3) for
                            // the newly-bonded validator's draw wallet @W_v, mirror
                            // of the genesis bonded-set install. VH = nil, so
                            // VB = for(phlo<-@W_v){ *phlo }. The wallet starts EMPTY
                            // (no phlogiston minted at bond — bond is a USER deploy
                            // with no sysAuthToken; minting happens on the
                            // authorized epoch/bond mint path), so VB blocks until
                            // the validator is first funded — the DR-3 halt. The
                            // validator handler VH is composed IN PARALLEL by a
                            // later workstream WITHOUT modifying VB.
                            for (phlo <= @(*walletTag, userPk)) { *phlo } |
                            resultCh!(state.set("allBonds", state.get("allBonds").set(userPk, amount)), depositResult)
                          }
                          // If deposit is unsuccessful, the user is not bonded.
                          (false, errorMsg) => {
                            resultCh!(state, (false, "Bond deposit failed: " ++ errorMsg))
                          }
                        }
                      }
                    }
                  }
                }
              } |
              // Public method allowing validators to withdraw their bonded and accumulated funds.
              contract PoS(@"withdraw", @deployerId, returnCh) = {
                new userCh, processCh, blockDataCh,
                    getBlockData(`rho:block:data`)
                in {
                  // Consumes state and updates withdrawers map.
                  runMVar!(*stateCh, *processCh, *returnCh) |
                  getBlockData!(*blockDataCh) |
                  getUser!(deployerId, *userCh) |
                  for (@state, resultCh   <- processCh &
                       @userPk            <- userCh &
                       @blockNumber, _, _ <- blockDataCh) {
                    if (state.get("allBonds").contains(userPk)) {
                      // The withdrawal goes into effect at the start of the next epoch.
                      resultCh!(
                        state.set("pendingWithdrawers",
                                  state.get("pendingWithdrawers")
                                       .set(userPk,
                                         $$quarantineLength$$ + $$epochLength$$ * (1 + blockNumber / $$epochLength$$))),
                        (true, Nil))
                    } else {
                      resultCh!(state, (false, "User is not bonded"))
                    }
                  }
                }
              } |
              // Private method which charges a deployer for a deploy.
              // Deployer's funds are deposited into the block sender's vault.
              // Return expects (Boolean, Either[Nil, String])
              // Per-deploy state holding `Map[deployerId -> initialPaymentAmount]`
              // for in-flight charges awaiting refund. Multi-signature deploys
              // accumulate one entry per cosigner; legacy single-sig deploys
              // hold exactly one entry. The Map shape eliminates the
              // non-deterministic `for` consumption hazard of the previous
              // single-tuple channel design when N > 1 cosigners are charged
              // in parallel — see the cost-accounted rho-calculus §3.2 Rules
              // 2-5 for the operational semantics this realizes.
              new posDeployStateTag in {
                // `posDeployStateTag` is a fresh genesis-scoped name used only
                // to build per-deploy-group state channels `@(*posDeployStateTag,
                // deployGroupId)`. Each distinct deploy/branch gets a distinct
                // `deployGroupId` (see system_deploy_util::deploy_group_id), so
                // its charge-tracking Produce has a distinct content-addressed
                // identity even when the tracked value is an identical `{}` —
                // this is what stops the multi-parent merge engine from flagging
                // independent deploys as conflicting/dependent. A deploy's N
                // cosigners share one channel (dedup/cap/refund preserved).
                //
                // NOTE: no single global `{}` seed here. The map is seeded once
                // per group, on the first cosigner's charge (`isFirst`), which is
                // safe because a deploy's cosigner charges run SEQUENTIALLY (an
                // awaited Rust loop in play_deploy_with_cost_accounting_cosigned),
                // so there is no race among one deploy's charges.
                //
                // @W_v := @(*walletTag, validatorPk) (the per-validator phlogiston
                // DRAW wallet; `walletTag` is allocated in the PoS-state scope
                // above) is — by the SAME content-addressing rationale these
                // charge-tracking channels rely on — unforgeable (private tag),
                // deterministic, INJECTIVE in validatorPk (distinct pubkeys ⇒
                // distinct channels, formalized in
                // formal/rocq/cost_accounted_rho/theories/WalletNaming.v as
                // `wallet_name_injective`), replay-stable, and merge-safe (distinct
                // validators' mints get distinct Produce identities). DR-13: @W_v
                // is DISTINCT from the supply pool Σ⟦v⟧ = from_sig(Ground(pk)); the
                // Σ⟦v⟧ balance datum (TOKEN_TAG, n) is a Rust `produce_balance`
                // concern, NOT built here (Rholang cannot name Σ⟦v⟧). @W_v holds a
                // MakeMint purse — the draw representation.

                // Private method which mints `amount` phlogiston into the validator's
                // draw wallet @W_v := @(*walletTag, validatorPk) (Cost-Accounted Rho,
                // spec Appendix B; DR-13). Authority root: a valid `sysAuthToken`
                // (GSysAuthToken), constructible ONLY by Rust system deploys via
                // `mk_sys_auth_token` (system_deploy.rs) — reachable from the
                // epoch/bond mint path that always holds the validator pubkey.
                // On a VALID token: deposit a fresh MakeMint purse of `amount` onto
                // @W_v and `return!(true)`. On an INVALID/absent token: deposit
                // NOTHING and `return!((false, "unauthorized mint"))`.
                // Return expects Boolean | (Boolean, String).
                contract PoS(@"mintPhlogiston", @validatorPk, @amount, @sysAuthToken, return) = {
                  new isValidTokenCh in {
                    sysAuthTokenOps!("check", sysAuthToken, *isValidTokenCh) |
                    for (@isValid <- isValidTokenCh) {
                      if (isValid) {
                        // Authorized: mint a purse of `amount` and deposit it onto
                        // the validator's draw wallet. The bootstrap VB
                        // (for(phlo<-@W_v){...}) consumes this purse to release
                        // execution fuel into the ambient composition.
                        new mintCh in {
                          @MakeMint!(*mintCh) |
                          for (mint <- mintCh) {
                            new purseCh in {
                              mint!("makePurse", amount, *purseCh) |
                              for (purse <- purseCh) {
                                @(*walletTag, validatorPk)!(*purse) |
                                return!(true)
                              }
                            }
                          }
                        }
                      } else {
                        // Unauthorized: no deposit, explicit rejection. A forged or
                        // absent token cannot be a GSysAuthToken
                        // (system_processes.rs `sys_auth_token_ops`), so this branch
                        // is the sole outcome for any non-system caller.
                        return!((false, "unauthorized mint"))
                      }
                    }
                  }
                } |
                // Shared epoch/genesis mint fold (Cost-Accounted Rho, Stage B
                // Decision 2/3; DR-13). Folds over `allBonds` and mints `amount`
                // phlogiston into the draw wallet @W_v of every validator `pk`
                // that is ELIGIBLE for `epochIdx`:
                //
                //     eligible(pk) ≜ activeValidators.contains(pk)
                //                  ∧ ¬mintingHalted.contains(pk)
                //                  ∧ ¬mintedEpochs.contains((pk, epochIdx))
                //
                // For each eligible `pk`: (1) call `mintPhlogiston` (the @W_v
                // purse half — the authorized, sysAuthToken-gated draw deposit);
                // (2) record (pk, epochIdx) in `mintedEpochs` so a replayed /
                // multi-parent-duplicated mint is a no-op (idempotency); (3)
                // accumulate (pk, amount) into the returned mint list. The
                // returned `mintList` is published by `closeBlock` onto the
                // Rust-known, user-unforgeable env channel `sys:casper:mintList`,
                // which `CloseBlockDeploy::post_eval` reads to mirror each amount
                // into the SUPPLY POOL Σ⟦v⟧ = from_sig(Ground(pk)) — the half
                // Rholang cannot write (Σ⟦v⟧ is unnameable in Rholang, DR-13). The
                // @W_v purse and the Σ⟦v⟧ balance are I-DUAL: both derive from the
                // SAME `amount` literal in the SAME authorized close-block deploy.
                //
                // Returns (updatedState, mintList) on returnCh, where
                //   updatedState : the state with `mintedEpochs` extended, and
                //   mintList     : List[(PublicKey, Int)] of the (pk, amount) minted.
                contract mintPhlogistonToValidators(@state, @amount, @epochIdx, @sysAuthToken, returnCh) = {
                  new mintFold, seedCh in {
                    // The fold accumulator is the pair (stateSoFar, mintListSoFar).
                    seedCh!((state, [])) |
                    for (@seed <- seedCh) {
                      @ListOps!("fold", state.get("allBonds").toList(), seed, *mintFold, *returnCh) |
                      contract mintFold(@(pk, _bond), @(accState, accMints), resultCh) = {
                        if (
                          accState.get("activeValidators").contains(pk) and
                          (accState.get("mintingHalted").contains(pk) == false) and
                          (accState.get("mintedEpochs").contains((pk, epochIdx)) == false)
                        ) {
                          // Eligible: mint the @W_v purse half, then record the
                          // epoch and accumulate the (pk, amount) mint record. We
                          // sequence on `mintPhlogiston`'s ack so the deposit is
                          // committed before the fold advances.
                          new mintAckCh in {
                            PoS!("mintPhlogiston", pk, amount, sysAuthToken, *mintAckCh) |
                            for (@_mintAck <- mintAckCh) {
                              resultCh!((
                                accState.set("mintedEpochs", accState.get("mintedEpochs").add((pk, epochIdx))),
                                accMints ++ [(pk, amount)]
                              ))
                            }
                          }
                        } else {
                          // Not eligible (inactive, halted, or already minted this
                          // epoch): no @W_v deposit, no Σ⟦v⟧ write, no record.
                          resultCh!((accState, accMints))
                        }
                      }
                    }
                  }
                } |
                // Bootstrap for the genesis bonded set: install the spec's
                // persistent validator bootstrap VB for every initially-bonded
                // validator. Per spec Appendix B eq:39 and DR-3,
                //
                //     VB ≜ for(phlo <- @W_v){ VH | *phlo }
                //
                // draws a phlogiston purse from the draw wallet @W_v and releases
                // it (`*phlo` = drop(phlo)) into the ambient parallel composition,
                // where the validator handler VH consumes it. An empty @W_v leaves
                // this for-comprehension with no message ⇒ it BLOCKS ⇒ the
                // validator is effectively offline (the DR-3 halt mechanism, spec
                // Appendix B "Slashing": removing the wallet's contents immediately
                // halts the validator). This is FULLY FUNCTIONAL, not a stub: the
                // validator handler VH is lifted into Rholang and composed IN
                // PARALLEL (Rholang `|`) by a later workstream WITHOUT modifying VB;
                // here VH = nil, so VB = for(phlo<-@W_v){ *phlo }. The `!` makes it
                // persistent (a production validator re-draws after each deploy,
                // spec Appendix B "Persistent validator": !VB).
                new genesisWalletPksCh, installVB, installVBDoneCh in {
                  @ListOps!("map", $$initialBonds$$.toList(), *fst, *genesisWalletPksCh) |
                  for (@genesisWalletPks <- genesisWalletPksCh) {
                    @ListOps!("foreach", genesisWalletPks, *installVB, *installVBDoneCh) |
                    contract installVB(@validatorPk, ackCh) = {
                      // VH = nil; VB = for(phlo<-@W_v){ nil | *phlo } = for(phlo<-@W_v){ *phlo }.
                      for (phlo <= @(*walletTag, validatorPk)) { *phlo } |
                      ackCh!(Nil)
                    }
                  }
                } |

                // Private method which charges a deployer for a deploy.
                // Deployer's funds are deposited into the block sender's vault.
                // Return expects (Boolean, Either[Nil, String])
                contract PoS(@"chargeDeploy", @deployerId, @deployGroupId, @isFirst, @amount, @sysAuthToken, return) = {
                  new isValidTokenCh in {
                    sysAuthTokenOps!("check", sysAuthToken, *isValidTokenCh) |
                    for (@isValid <- isValidTokenCh) {
                      if (isValid) {
                        // Seed the group-scoped map with `{}` exactly once, on the
                        // first cosigner. Inlined take/process/put on the
                        // group-scoped channel (rather than runMVar) because the
                        // channel is constructed dynamically from deployGroupId.
                        if (isFirst) { @(*posDeployStateTag, deployGroupId)!({}) } |
                        for (@state <- @(*posDeployStateTag, deployGroupId)) {
                          if (state.contains(deployerId)) {
                            // Defensive: never charge the same cosigner twice
                            // per deploy. Unreachable if the deploy-decode
                            // boundary's `Cosigned::from_signed_data`
                            // dedup invariant holds; surfaced as an explicit
                            // error for debuggability.
                            @(*posDeployStateTag, deployGroupId)!(state) |
                            return!((false, "Cosigner already charged for this deploy"))
                          } else if (state.size() >= $$maxCosignersPerDeploy$$) {
                            // Defense-in-depth: bound per-deploy cosigner
                            // count (configurable per shard via
                            // `casper_conf.rs::max_cosigners_per_deploy`).
                            @(*posDeployStateTag, deployGroupId)!(state) |
                            return!((false, "Cosigner cap exceeded for this deploy"))
                          } else {
                            new depositCh in {
                              deposit!(deployerId, amount, posVaultAddr, *depositCh) |
                              for (@depositResult <- depositCh){
                                match depositResult {
                                  (true, _) => {
                                    @(*posDeployStateTag, deployGroupId)!(state.set(deployerId, amount)) |
                                    return!(depositResult)
                                  }
                                  (_, errorMessage) => {
                                    @(*posDeployStateTag, deployGroupId)!(state) |
                                    return!((false, "Deploy payment failed: " ++ errorMessage))
                                  }
                                }
                              }
                            }
                          }
                        }
                      } else {
                        return!((false, "Invalid system auth token"))
                      }
                    }
                  }
                } |
                // Private method which refunds a deployer if too much was charged in chargeDeploy.
                // Funds are transferred from the block sender's vault to the deployer.
                // Takes an explicit `@deployerId` argument so multi-signature
                // refunds (one per cosigner) route to the correct vault.
                // Return expects (Boolean, Either[Nil, String])
                contract PoS(@"refundDeploy", @deployerId, @deployGroupId, @refundAmount, @sysAuthToken, return) = {
                  new isValidTokenCh in {
                    sysAuthTokenOps!("check", sysAuthToken, *isValidTokenCh) |
                    for (@isValid <- isValidTokenCh) {
                      if (isValid) {
                        // Inlined take/process/put on the SAME group-scoped
                        // channel the pre-charge used. The residual `{}` left
                        // after the last delete does not collide with other
                        // deploys (the channel is deploy-unique), so no teardown.
                        for (@state <- @(*posDeployStateTag, deployGroupId)) {
                          match state.get(deployerId) {
                            Nil => {
                              // No in-flight charge recorded for this deployerId.
                              // Map remains unchanged.
                              @(*posDeployStateTag, deployGroupId)!(state) |
                              return!((false, "No in-flight charge for this deployer"))
                            }
                            initialPaymentAmount => {
                              if (refundAmount < 0) {
                                @(*posDeployStateTag, deployGroupId)!(state.delete(deployerId)) |
                                return!((false, "Invalid refund amount"))
                              } else if (refundAmount > initialPaymentAmount) {
                                @(*posDeployStateTag, deployGroupId)!(state.delete(deployerId)) |
                                return!((false, "Refund exceeds initial deploy payment"))
                              } else if (refundAmount > 0) {
                                new vaultAddressCh, transferCh in {
                                  vaultAddressOps!("fromDeployerId", deployerId, *vaultAddressCh) |
                                  for (@deployerVaultAddress <- vaultAddressCh) {
                                    // Transfer (from sender to deployer) called in refundDeploy.
                                    @posVault!("transfer", deployerVaultAddress, refundAmount, posAuthKey, *transferCh) |
                                    for (@transferResult <- transferCh) {
                                      match transferResult {
                                        (true, _) => {
                                          @(*posDeployStateTag, deployGroupId)!(state.delete(deployerId)) |
                                          return!((true, Nil))
                                        }
                                        (_, errorMessage) => {
                                          @(*posDeployStateTag, deployGroupId)!(state.delete(deployerId)) |
                                          return!((false, "(Bug found) Deploy refund failed: " ++ errorMessage))
                                        }
                                      }
                                    }
                                  }
                                }
                              } else {
                                // refundAmount == 0: no transfer needed; clean
                                // up the Map entry so the cosigner cannot be
                                // re-refunded.
                                @(*posDeployStateTag, deployGroupId)!(state.delete(deployerId)) |
                                return!((true, Nil))
                              }
                            }
                          }
                        }
                      } else {
                        return!((false, "Invalid system auth token"))
                      }
                    }
                  }
                }
              } |
              new commitRewards in {
                // Private method which transfers all of a validator's rewards + bond to the Coop vault.
                // Slash expects (Boolean, Either[Nil, String]) on returnCh.
                contract PoS(@"slash", @deployerId, @blockHash, @sysAuthToken, returnCh) = {
                  new isValidTokenCh in {
                    sysAuthTokenOps!("check", sysAuthToken, *isValidTokenCh) |
                    for (@isValid <- isValidTokenCh) {
                      if (isValid) {
                        new invalidBlocksCh, stateProcessCh, userCh,
                            getInvalidBlocks(`rho:casper:invalidBlocks`)
                        in {
                          getInvalidBlocks!(*invalidBlocksCh) |
                          getUser!(deployerId, *userCh) |
                          runMVar!(*stateCh, *stateProcessCh, *returnCh) |
                          for (@invalidBlocks        <- invalidBlocksCh &
                               @userPk               <- userCh &
                               @state, stateUpdateCh <- stateProcessCh) {
                                new toBeSlashed, valBondCh, valRewardCh in {
                                  if (invalidBlocks.contains(blockHash)) {
                                    toBeSlashed!(invalidBlocks.get(blockHash)) |
                                    for (@validator <- toBeSlashed) {
                                      valBondCh!(state.get("allBonds").get(validator)) |
                                      for (@valBond <- valBondCh) {
                                        // Idempotency: a validator already at
                                        // stake 0 has been slashed by a prior
                                        // call. The transfer of `valBond = 0`
                                        // would fail with "Amount must be
                                        // positive value", but the desired
                                        // end state (validator at 0, removed
                                        // from active set) is already reached.
                                        // Returning (true, Nil) here makes
                                        // PoS!"slash" safe to invoke from
                                        // every block whose body re-issues a
                                        // SlashDeploy for the same offender —
                                        // a requirement for the
                                        // merge-rejected-slash recovery
                                        // path (`merging::rejected_slash::
                                        // filter_recoverable`) and for the
                                        // T-9.3 catch-all dispatcher that
                                        // mints a record per slashable
                                        // variant.
                                        if (valBond <= 0) {
                                          stateUpdateCh!(state, (true, Nil))
                                        } else {
                                          new transferDoneCh in {
                                            @posVault!(
                                              "transfer",
                                              coopMultiVaultAddr,
                                              valBond,
                                              posAuthKey,
                                              *transferDoneCh
                                            ) |
                                            for (@transferResult <- transferDoneCh) {
                                              match transferResult {
                                                (true, _) => {
                                                  stateUpdateCh!({
                                                    "allBonds"        : state.get("allBonds").set(validator, 0),
                                                    "activeValidators": state.get("activeValidators").delete(validator),
                                                    "committedRewards" : state.get("committedRewards").delete(validator),
                                                    "withdrawers"     : state.get("withdrawers"),
                                                    "pendingWithdrawers": state.get("pendingWithdrawers"),
                                                    "randomImages"    : state.get("randomImages"),
                                                    "randomNumbers"   : state.get("randomNumbers")
                                                  },
                                                  (true, Nil))
                                                }
                                                (_, errorMessage) => {
                                                  stateUpdateCh!(state, (false, "transfer failed: " ++ errorMessage))
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  } else {
                                    stateUpdateCh!(state, (false, "invalid slash evidence"))
                                  }
                                }
                          }
                        }
                      } else {
                        returnCh!((false, "Invalid system auth token"))
                      }
                    }
                  }
                } |
                // Private method which signals the end of block processing.
                //
                // Cost-Accounted Rho Stage B (Decision 2): closeBlock now also
                // performs the per-validator phlogiston MINT. `mintList` is a
                // Rust-supplied, user-unforgeable channel (CloseBlockDeploy env
                // `sys:casper:mintList`); closeBlock publishes onto it the list
                // List[(PublicKey, Int)] of (pk, amount) it minted this block, and
                // `CloseBlockDeploy::post_eval` reads it to mirror each amount into
                // the supply pool Σ⟦v⟧ (the half Rholang cannot write — DR-13).
                // Two mint paths share `mintPhlogistonToValidators`:
                //   * the steady EPOCH mint (blockNumber % epochLength == 0):
                //     amount = epochPhlogiston, epochIdx = blockNumber/epochLength;
                //   * the GENESIS BLOCK-1 mint (blockNumber == 1, non-epoch
                //     branch): amount = initialPhlogiston, epochIdx = 0 — funds the
                //     genesis bonded set. Newly-bonded validators get their first
                //     mint on the next epoch boundary (the same fold; the catch-up
                //     needs no separate set — spec draws no such distinction).
                contract PoS(@"closeBlock", @sysAuthToken, mintList, ackCh) = {
                  new isValidTokenCh in {
                    sysAuthTokenOps!("check", sysAuthToken, *isValidTokenCh) |
                    for (@isValid <- isValidTokenCh) {
                      if (isValid) {
                        new blockDataCh, getBlockData(`rho:block:data`) in {
                          getBlockData!(*blockDataCh) |
                          for (@blockNumber, _, _ <- blockDataCh) {
                            if (blockNumber % $$epochLength$$ != 0) {
                              // Epoch change does not occur. Lifted to the
                              // runMVar/stateUpdateCh pattern (Stage B) so the
                              // genesis block-1 mint can extend `mintedEpochs` in
                              // state. On block 1, mint `initialPhlogiston` to the
                              // genesis bonded set (epochIdx 0); otherwise no mint
                              // (publish an empty mint list so post_eval mirrors
                              // nothing).
                              new stateProcessCh in {
                                runMVar!(*stateCh, *stateProcessCh, *ackCh) |
                                for (@state, stateUpdateCh <- stateProcessCh) {
                                  if (blockNumber == 1) {
                                    new mintedCh in {
                                      mintPhlogistonToValidators!(state, $$initialPhlogiston$$, 0, sysAuthToken, *mintedCh) |
                                      for (@(mintedState, mints) <- mintedCh) {
                                        mintList!(mints) |
                                        stateUpdateCh!(mintedState, (true, Nil))
                                      }
                                    }
                                  } else {
                                    mintList!([]) |
                                    stateUpdateCh!(state, (true, Nil))
                                  }
                                }
                              }
                            } else {
                              // Epoch change occurs.
                              new payWithdrawer, removeQuarantinedWithdrawers,
                                  stateProcessCh, paymentDoneCh,
                                  accDepositsDoneCh, commitRewardsCh,
                                  newValidatorsCh, removeQuarantinedCh, currentEpochRewardCh,
                                  commitCurrentEpochRewards, updatedRewardsCh, movePendingWithdrawCh, movePendingWithdrawer,
                                  epochMintedCh
                              in {
                                PoS!("getCurrentEpochRewards", * currentEpochRewardCh) |
                                for (@currentRewards <- currentEpochRewardCh) {
                                  runMVar!(*stateCh, *stateProcessCh, *ackCh) |
                                  for (@state, stateUpdateCh <- stateProcessCh) {
                                    // 1. Calculate all the validator current epoch rewards based on active validator bonding proportion
                                    // 2. Accumulate `committedRewards` with the result of step 1
                                    commitCurrentEpochRewards!(state, currentRewards, *updatedRewardsCh) |
                                    for (@newCommittedState <- updatedRewardsCh) {
                                      // 3. Update `withdrawers` according to `allBonds` and `pendingWithdrawers`
                                      // when pendingWithdrawers is not empty, remove the validator in `allBonds`
                                      movePendingWithdrawer!(newCommittedState, *movePendingWithdrawCh) |
                                      for (@newMovedPendingState <- movePendingWithdrawCh){
                                        // 4. When the block number reaches the quantinue of `withdrawers` ,
                                        //  transfer the corresponding bonds+ rewards to the corresponding validator from posVault.
                                        // 5. update `pendingWithdrawers` to empty Map {}.
                                        removeQuarantinedWithdrawers!(blockNumber, newMovedPendingState, *removeQuarantinedCh) |
                                        for (@newRemovedQuantinueState <- removeQuarantinedCh) {
                                          // 6. Pick new `activeValidators`
                                          pickActiveValidators!(newMovedPendingState.get("allBonds").toList(), *newValidatorsCh) |
                                          for (@newValidators <- newValidatorsCh) {
                                            // 7. Cost-Accounted Rho Stage B: mint
                                            //    `epochPhlogiston` to every ACTIVE,
                                            //    non-halted, not-yet-minted-this-epoch
                                            //    validator (eligibility uses the
                                            //    NEWLY-PICKED active set), recording
                                            //    (pk, epochIdx) in `mintedEpochs`.
                                            //    Publish the (pk, amount) mint list to
                                            //    `mintList` for post_eval's Σ⟦v⟧ mirror.
                                            mintPhlogistonToValidators!(
                                              newRemovedQuantinueState.set("activeValidators", newValidators),
                                              $$epochPhlogiston$$,
                                              blockNumber / $$epochLength$$,
                                              sysAuthToken,
                                              *epochMintedCh
                                            ) |
                                            for (@(epochMintedState, epochMints) <- epochMintedCh) {
                                              mintList!(epochMints) |
                                              stateUpdateCh!(epochMintedState, (true, Nil))
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                } |
                                // Transfers withdrawing validator's bond + accumulated rewards from PoS vault to their vault.
                                contract payWithdrawer(@(pk, amount), returnCh) = {
                                  new vaultCh, vaultAddressCh, createCh in {
                                    vaultAddressOps!("fromPublicKey", pk, *vaultAddressCh) |
                                    for (@toVaultAddress <- vaultAddressCh) {
                                      @SystemVault!("findOrCreate", toVaultAddress, *createCh) |
                                      for (@_ <- createCh){
                                        @posVault!("transfer", toVaultAddress, amount, posAuthKey, *returnCh)
                                      }
                                    }
                                  }
                                } |
                                contract commitCurrentEpochRewards(@state, @currentRewards, returnCh) = {
                                  new accumulate in {
                                    @ListOps!("fold", currentRewards.toList(), state, *accumulate, *returnCh) |
                                    contract accumulate(@(pk, reward), @updatedState, resultCh) = {
                                      resultCh!(updatedState.set("committedRewards",
                                                                  updatedState.get("committedRewards").set(pk, updatedState.get("committedRewards").getOrElse(pk, 0) + reward)))
                                    }
                                  }
                                } |
                                contract movePendingWithdrawer(@state, returnCh) = {
                                  new movePending in {
                                    @ListOps!("fold", state.get("pendingWithdrawers").toList(), state, *movePending, *returnCh) |
                                    contract movePending(@(pk, quantine), @updatedState, resultCh) = {
                                      resultCh!(updatedState
                                                .set("withdrawers", updatedState.get("withdrawers").set(pk, (updatedState.get("allBonds").get(pk), quantine)))
                                                .set("allBonds", updatedState.get("allBonds").delete(pk))
                                                .set("pendingWithdrawers", updatedState.get("pendingWithdrawers").delete(pk))
                                                )
                                    }
                                  }
                                } |
                                // Checks withdrawer's quarantine period against current block number,
                                // then computes their payment, removes them from the bonds and withdrawers maps, and
                                // updates the committed rewards map.
                                contract removeQuarantinedWithdrawers(@currentBlockNumber, @state, returnCh) = {
                                  new quarantinedValidatorsCh, validatorsToWithdrawListCh,
                                      isQuarantineFinished, notWithdrawn, payWithdraw,
                                      newBondsListCh, newWithdrawersListCh,
                                      computeRemove, payRet
                                  in {
                                    // Calculate rewards by taking PoS balance on PoS vault and subtract all active stake + newly bonded
                                    @ListOps!("filter", state.get("withdrawers").toList(), *isQuarantineFinished, *quarantinedValidatorsCh) |
                                    for (@quarantinedValidators <- quarantinedValidatorsCh) {
                                      @ListOps!("unorderedParMap", quarantinedValidators, *payWithdraw, *payRet) |
                                      // Bug #10 fix: pattern-match on the transfer outcome and emit
                                      // (pk, success_bool) on resultCh. The downstream `computeRemove`
                                      // fold then removes ONLY successful withdrawers from the maps;
                                      // failed transfers leave the per-validator state intact for
                                      // retry on a later block. Pre-fix the resultCh just forwarded
                                      // posVault.transfer's (true, _) | (false, errMsg) pair, and the
                                      // surrounding `for (@_ <- payRet)` accepted any value, so a
                                      // failed transfer would still drop the validator from
                                      // `withdrawers` and `committedRewards` — losing funds. See
                                      // design/09-bug-fixes-and-rationale.md §9.13
                                      // (theorem t_9_10_withdraw_transfer_failure_safety,
                                      // formal/rocq/slashing/theories/BugFixWithdrawTransferFailure.v).
                                      contract payWithdraw(@(pk, (bonds, quantine)), resultCh) = {
                                        new transferResultCh in {
                                          payWithdrawer!((pk, bonds + state.get("committedRewards").getOrElse(pk, 0)), *transferResultCh) |
                                          for (@transferResult <- transferResultCh) {
                                            match transferResult {
                                              (true, _) => { resultCh!((pk, true)) }
                                              (_, _)    => { resultCh!((pk, false)) }
                                            }
                                          }
                                        }
                                      } |
                                      for (@payResults <- payRet) {
                                        @ListOps!("fold", payResults, state, *computeRemove, *returnCh) |
                                        contract computeRemove(@(pk, success), @updatedState, resultCh) = {
                                          if (success) {
                                            resultCh!(updatedState
                                                      .set("committedRewards", updatedState.get("committedRewards").delete(pk))
                                                      .set("withdrawers", updatedState.get("withdrawers").delete(pk))
                                                      )
                                          } else {
                                            // Failure path: leave per-validator state intact so the
                                            // outer scheduler retries on a later block. The validator
                                            // remains in `withdrawers` with their original (bond,
                                            // quarantine) entry and unchanged `committedRewards`.
                                            resultCh!(updatedState)
                                          }
                                        }
                                      }
                                    } |
                                    // Check whether quarantine period is finished.
                                    contract isQuarantineFinished(@(pk, (bonds, blockNumber)), resultCh) = {
                                      resultCh!(currentBlockNumber >= blockNumber)
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      } else {
                        ackCh!((false, "Invalid system auth token"))
                      }
                    }
                  }
                }
              } |
              //
              contract PoS(@"commitRandomImage", @deployerId, @hash, ackCh) = {
                new userCh, mvarCh in {
                  getUser!(deployerId, *userCh) |
                  runMVar!(*stateCh, *mvarCh, *ackCh) |
                  for (@validator       <- userCh &
                       @state, resultCh <- mvarCh) {
                    if (state.get("randomImages").contains(validator)) {
                      resultCh!(state, (false, "Image already committed"))
                    } else {
                      resultCh!(
                        state.set("randomImages", state.get("randomImages").set(validator, hash)), true)
                    }
                  }
                }
              } |
              //
              contract PoS(@"revealRandom", @deployerId, @random, ackCh) = {
                new userCh, mvarCh, computeHash(`rho:crypto:keccak256Hash`), hashCh in {
                  getUser!(deployerId, *userCh) |
                  runMVar!(*stateCh, *mvarCh, *ackCh) |
                  computeHash!(random, *hashCh) |
                  for (@validator       <- userCh &
                       @state, resultCh <- mvarCh &
                       @hash            <- hashCh) {
                    if (state.get("randomImages").contains(validator)) {
                      if (hash == state.get("randomImages").get(validator)) {
                        resultCh!(
                          state.set("randomNumbers",state.get("randomNumbers").set(validator, random)), true)
                      } else {
                        resultCh!(state, (false, "Previously committed image doesn't match the random number"))
                      }
                    } else {
                      resultCh!(state, (false, "Previously committed random image not found"))
                    }
                  }
                }
              }
            }
          }
        } |
        // Transfers funds from deployer to block sender.
        contract deposit(@deployerId, @amount, @toTargetAddress, returnCh) = {
          new vaultCh, vaultAddressCh,
              indexSender, authKeyCh
          in {
            @SystemVault!("deployerAuthKey", deployerId, *authKeyCh) |
            vaultAddressOps!("fromDeployerId", deployerId, *vaultAddressCh) |
            for (@authKey        <- authKeyCh &
                 @fromVaultAddress <- vaultAddressCh) {
              @SystemVault!("findOrCreate", fromVaultAddress, *vaultCh) |
              for (@(true, fromVault) <- vaultCh) {
                // Transfers from deployer to PoS vault
                @fromVault!("transfer", toTargetAddress, amount, authKey, *returnCh)
              }
            }
          }
        }
      } |
      // Updates value stored on varCh and sends (Bool) acknowledgement on returnCh.
      contract runMVar(varCh, processCh, returnCh) = {
        new resultCh in {
          for (@v <- varCh) {
            processCh!(v, *resultCh) |
            for (@newV, @result <- resultCh) {
              varCh!(newV) |
              returnCh!(result)
            }
          }
        }
      } |
      // Discards second element of a pair.
      contract fst(@(first, _), resultCh) = {
        resultCh!(first)
      } |
      // For computing some of initial validator bonds.
      contract sumFromPair(@(_, a), @b, resultCh) = {
        resultCh!(a + b)
      } |
      // Retrieves deployer's public key.
      contract getUser(@deployerId, returnCh) = {
        new deployerIdOps(`rho:system:deployerId:ops`) in {
          deployerIdOps!("pubKeyBytes", deployerId, *returnCh)
        }
      } |
      // Selects set of active validators from the set of available validators.
      contract pickActiveValidators(@allBonds, returnCh) = {
        new availableValidatorsCh,
            isAvailable, pksCh
        in {
          @ListOps!("map", allBonds, *fst, *pksCh) |
          for (@pks <- pksCh) {
            // TODO: Randomly select 100 active validators once we have on-chain randomness
            returnCh!(pks.take($$numberOfActiveValidators$$).toSet())
          }
        }
      }
    }
    }|
    // Registers signed write-only PoS contract bundle.
    rs!(
      "047b43d6548b72813b89ac1b9f9ca67624a8b372feedd71d4e2da036384a3e1236812227e524e6f237cde5f80dbb921cac12e6500791e9a9ed1254a745a816fe1f".hexToBytes(),
      (9223372036854775807, bundle+{*PoS}),
      "3045022100cd1a32e04e21deb1bb3cd108cb0a3ab1357495f6ad99dfeb08eb17eaa082d388022015a9c5f9cd3b489a1fe3e359dbfe791ddd7d66e8a9a1dfb4978c980128c53f69".hexToBytes(),
      *uriOut)
  }
}
