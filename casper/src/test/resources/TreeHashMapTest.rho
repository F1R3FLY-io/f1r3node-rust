new
  rl(`rho:registry:lookup`), RhoSpecCh,
  stdlog(`rho:io:stdlog`),
  test_get_before_set,
  test_get_after_set,
  test_get_after_update_nil,
  test_get_after_update,
  test_fast_unsafe_get_after_set,
  test_contains_before_set,
  test_contains_after_set,
  test_get_after_set_to_nil,
  test_contains_after_set_to_nil,
  test_contention,
  test_depth_matches_init,
  test_get_or_else_when_key_missing,
  test_get_or_else_when_key_present,
  test_delete_key,
  test_delete_missing_key,
  test_set_after_delete_returns_new_value,
  test_delete_preserves_unrelated_keys,
  test_set_delete_set_cycles,
  test_update_after_delete,
  test_to_map_after_delete,
  test_treehashmap_depth_1,
  test_get_or_else_after_delete,
  test_bulk_insert_then_bulk_delete_then_reinsert,
  test_convert_to_map_0_values,
  test_convert_to_map_1_values,
  test_convert_to_map_2_values,
  test_convert_to_map_3_values,
  test_convert_to_map_4_values
in {
  rl!(`rho:id:zphjgsfy13h1k85isc8rtwtgt3t9zzt5pjd5ihykfmyapfc4wt3x5h`, *RhoSpecCh) |
  for(@(_, RhoSpec) <- RhoSpecCh) {
    @RhoSpec!("testSuite",
      [
        ("Get before set returns Nil", *test_get_before_set),
        ("Get after set returns the new value", *test_get_after_set),
        ("Get after updating a nonexistent key should return Nil", *test_get_after_update_nil),
        ("Get after updating an existing key should return the right value", *test_get_after_update),
        ("Fast unsafe get after set returns the new value", *test_fast_unsafe_get_after_set),
        ("Contains before set returns false", *test_contains_before_set),
        ("Contains after set returns true", *test_contains_after_set),
        ("Get after set to Nil returns Nil", *test_get_after_set_to_nil),
        ("Contains after set to Nil returns true", *test_contains_after_set_to_nil),
        ("Works under contention", *test_contention),
        ("Depth matches init", *test_depth_matches_init),
        ("GetOrElse when key missing", *test_get_or_else_when_key_missing),
        ("GetOrElse when key present", *test_get_or_else_when_key_present),
        ("Delete key", *test_delete_key),
        ("Delete missing key", *test_delete_missing_key),
        ("Set after delete returns new value", *test_set_after_delete_returns_new_value),
        ("Delete does not affect unrelated keys", *test_delete_preserves_unrelated_keys),
        ("Repeated set/delete cycles preserve final value", *test_set_delete_set_cycles),
        ("Update after delete behaves like update on never-set", *test_update_after_delete),
        ("ToMap reflects deletions", *test_to_map_after_delete),
        ("TreeHashMap with depth=1 (max interior sharing)", *test_treehashmap_depth_1),
        ("GetOrElse returns default after delete", *test_get_or_else_after_delete),
        ("Bulk insert + bulk delete + bulk reinsert", *test_bulk_insert_then_bulk_delete_then_reinsert),
        ("Convert to map 0 values", *test_convert_to_map_0_values),
        ("Convert to map 1 values", *test_convert_to_map_1_values),
        ("Convert to map 2 values", *test_convert_to_map_2_values),
        ("Convert to map 3 values", *test_convert_to_map_3_values),
        ("Convert to map 4 values", *test_convert_to_map_4_values),
      ])
  } |

  new TreeHashMapCh in {
    rl!(`rho:lang:treeHashMap`, *TreeHashMapCh) |
    for(TreeHashMap <- TreeHashMapCh) {
      contract test_get_before_set(rhoSpec, _, ackCh) = {
        new ret, ch in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("get", thm, "no such key", *ch) |
            rhoSpec!("assert", (Nil, "== <-", *ch), "Getting with an unused key returns Nil", *ackCh)
          }
        }
      } |

      contract test_get_after_update_nil(rhoSpec, _, ackCh) = {
        new thmCh, ack, ch, update in {
          TreeHashMap!("init", 3, *thmCh) |
          contract update(@val, ret) = {
            ret!(val + 1)
          } |
          for (@thm <- thmCh) {
            TreeHashMap!("update", thm, "no such key", *update, *ack) |
            for (_ <- ack) {
              TreeHashMap!("get", thm, "no such key", *ch) |
              rhoSpec!("assert", (Nil, "== <-", *ch), "Getting after updating with an unused key returns Nil", *ackCh)
            }
          }
        }
      } |

      contract test_get_after_update(rhoSpec, _, ackCh) = {
        new thmCh, ack1, ack2, ch, update in {
          TreeHashMap!("init", 3, *thmCh) |
          contract update(@val, ret) = {
            ret!(val + 1)
          } |
          for (@thm <- thmCh) {
            TreeHashMap!("set", thm, "key", 0, *ack1) |
            for (_ <- ack1) {
              TreeHashMap!("update", thm, "key", *update, *ack2) |
              for (_ <- ack2) {
                TreeHashMap!("get", thm, "key", *ch) |
                rhoSpec!("assert", (1, "== <-", *ch), "Getting after updating after setting returns the right value", *ackCh)
              }
            }
          }
        }
      } |

      contract test_get_after_set(rhoSpec, _, ackCh) = {
        new ret, ch1, ch2 in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key", "some val", *ch1) |
            for (_ <- ch1) {
              TreeHashMap!("get", thm, "some key", *ch1) |
              TreeHashMap!("get", thm, "some other key", *ch2) |
              rhoSpec!("assertMany",
                [
                  (("some val", "== <-", *ch1), "Getting with the proper key returns the correct value"),
                  ((Nil, "== <-", *ch2), "Getting with a different key returns Nil")
                ], *ackCh)
            }
          }
        }
      } |

      contract test_fast_unsafe_get_after_set(rhoSpec, _, ackCh) = {
        new ret, ch1, ch2 in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key", "some val", *ch1) |
            for (_ <- ch1) {
              TreeHashMap!("fastUnsafeGet", thm, "some key", *ch2) |
              rhoSpec!("assert", ("some val", "== <-", *ch2), "Getting with the proper key returns the correct value", *ackCh)
            }
          }
        }
      } |

      contract test_contains_before_set(rhoSpec, _, ackCh) = {
        new ret, ch in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("contains", thm, "no such key", *ch) |
            rhoSpec!("assert", (false, "== <-", *ch), "Getting with an unused key returns false", *ackCh)
          }
        }
      } |

      contract test_contains_after_set(rhoSpec, _, ackCh) = {
        new ret, ch1, ch2, ch3 in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key", "some val", *ch1) |
            for (_ <- ch1) {
              TreeHashMap!("contains", thm, "some key", *ch2) |
              TreeHashMap!("contains", thm, "some other key", *ch3) |
              rhoSpec!("assertMany",
                [
                  ((true, "== <-", *ch2), "Getting with the proper key returns true"),
                  ((false, "== <-", *ch3), "Getting with a different key returns false")
                ], *ackCh)
            }
          }
        }
      } |

      contract test_get_after_set_to_nil(rhoSpec, _, ackCh) = {
        new ret, ch1, ch2 in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key", Nil, *ch1) |
            for (_ <- ch1) {
              TreeHashMap!("get", thm, "some key", *ch2) |
              rhoSpec!("assert", (Nil, "== <-", *ch2), "Getting with the proper key returns the correct value", *ackCh)
            }
          }
        }
      } |

      contract test_contains_after_set_to_nil(rhoSpec, _, ackCh) = {
        new ret, ch1, ch2, ch3 in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key", Nil, *ch1) |
            for (_ <- ch1) {
              TreeHashMap!("contains", thm, "some key", *ch2) |
              TreeHashMap!("contains", thm, "some other key", *ch3) |
              rhoSpec!("assertMany",
                [
                  ((true, "== <-", *ch2), "Getting with the proper key returns true"),
                  ((false, "== <-", *ch3), "Getting with a different key returns false")
                ], *ackCh)
            }
          }
        }
      } |

      contract test_contention(rhoSpec, _, ackCh) = {
        new tryIt in {
          contract tryIt(@n, @flag) = {
            new out(`rho:io:stdlog`), mapCh in {
              TreeHashMap!("init", 3, *mapCh) |
              for (@map <- mapCh) {
                new ret1, ret2, ret3 in {
                  TreeHashMap!("set", map, "category", "object", *ret1) |
                  TreeHashMap!("set", map, "category", "morphism", *ret2) |
                  for (_ <- ret1 & _ <- ret2) {
                    TreeHashMap!("get", map, "category", *ret3) |
                    for (@val3 <- ret3) {
                      out!("info", [n, val3]) |
                      if (n == 9) {
                        rhoSpec!("assert", (flag, "==", true), "Placeholder", *ackCh)
                      } else {
                        tryIt!(n+1, flag and (val3 != Nil))
                      }
                    }
                  }
                }
              }
            }
          } |
          tryIt!(0, true)
        }
      } |

      contract test_depth_matches_init(rhoSpec, _, ackCh) = {
        new ret, ch in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("depth", thm, *ch) |
            rhoSpec!("assert", (3, "== <-", *ch), "Depth returns same value provided to init", *ackCh)
          }
        }
      } |

      contract test_get_or_else_when_key_missing(rhoSpec, _, ackCh) = {
        new ret, valueCh, nilCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("getOrElse", thm, 0, *valueCh, *nilCh) |
            rhoSpec!("assert", ("nothing <-", *nilCh), "nilCh is triggered when key is missing", *ackCh)
          }
        }
      } |

      contract test_get_or_else_when_key_present(rhoSpec, _, ackCh) = {
        new ret, ch1, valueCh, nilCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key", "some val", *ch1) |
            for (_ <- ch1) {
              TreeHashMap!("getOrElse", thm, "some key", *valueCh, *nilCh) |
              rhoSpec!("assert", ("some val", "== <-", *valueCh), "valueCh is triggered when key is present", *ackCh)
            }
          }
        }
      } |

      contract test_delete_key(rhoSpec, _, ackCh) = {
        new ret, ch1, deleteCh, getAfterDeleteCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key", "some val", *ch1) |
            for (_ <- ch1) {
              TreeHashMap!("delete", thm, "some key", *deleteCh) |
              for (@deleted <- deleteCh) {
                TreeHashMap!("get", thm, "some key", *getAfterDeleteCh) |
                rhoSpec!("assertMany",
                  [
                    (("some val", "==", deleted), "deleteCh contains deleted value"),
                    ((Nil, "== <-", *getAfterDeleteCh), "value is not present in map"),
                  ], *ackCh)
              }
            }
          }
        }
      } |

      contract test_delete_missing_key(rhoSpec, _, ackCh) = {
        new ret, deleteCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("delete", thm, "some key", *deleteCh) |
            rhoSpec!("assert", (Nil, "== <-", *deleteCh), "deleteCh contains Nil", *ackCh)
          }
        }
      } |

      // Deletion removes the leaf-Map entry but does NOT clear interior
      // bitmap bits — the same key-path can be re-used by a subsequent set
      // without rebuilding the interior chain. If a future change starts
      // clearing parent bits on delete, the re-set would land on a
      // freshly-MakeNode'd leaf with different unforgeable identities and
      // break BitmaskOr merging of concurrent inserts on this path.
      contract test_set_after_delete_returns_new_value(rhoSpec, _, ackCh) = {
        new ret, set1Ch, deleteCh, set2Ch, getCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "key", "first_value", *set1Ch) |
            for (_ <- set1Ch) {
              TreeHashMap!("delete", thm, "key", *deleteCh) |
              for (_ <- deleteCh) {
                TreeHashMap!("set", thm, "key", "second_value", *set2Ch) |
                for (_ <- set2Ch) {
                  TreeHashMap!("get", thm, "key", *getCh) |
                  rhoSpec!("assert", ("second_value", "== <-", *getCh),
                    "Re-setting a deleted key returns the new value",
                    *ackCh)
                }
              }
            }
          }
        }
      } |

      // Companion to the no-clear invariant: deleting one key must not
      // disturb the lookup of unrelated keys. Three keys are inserted, the
      // middle one is deleted, and the others are queried. If delete
      // accidentally cleared interior bitmap bits shared with the surviving
      // keys, those would lose their lookup path and return Nil here.
      contract test_delete_preserves_unrelated_keys(rhoSpec, _, ackCh) = {
        new ret, setACh, setBCh, setCCh, deleteCh, getACh, getCCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "alpha", "A", *setACh) |
            TreeHashMap!("set", thm, "beta", "B", *setBCh) |
            TreeHashMap!("set", thm, "gamma", "C", *setCCh) |
            for (_ <- setACh; _ <- setBCh; _ <- setCCh) {
              TreeHashMap!("delete", thm, "beta", *deleteCh) |
              for (_ <- deleteCh) {
                TreeHashMap!("get", thm, "alpha", *getACh) |
                TreeHashMap!("get", thm, "gamma", *getCCh) |
                rhoSpec!("assertMany",
                  [
                    (("A", "== <-", *getACh), "alpha survives delete-of-beta"),
                    (("C", "== <-", *getCCh), "gamma survives delete-of-beta"),
                  ],
                  *ackCh)
              }
            }
          }
        }
      } |

      // Repeated set/delete cycles on the same key. Interior nodes must
      // survive arbitrary cycle counts without state drift.
      contract test_set_delete_set_cycles(rhoSpec, _, ackCh) = {
        new ret, s1, d1, s2, d2, s3, getCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "k", "v1", *s1) |
            for (_ <- s1) {
              TreeHashMap!("delete", thm, "k", *d1) |
              for (_ <- d1) {
                TreeHashMap!("set", thm, "k", "v2", *s2) |
                for (_ <- s2) {
                  TreeHashMap!("delete", thm, "k", *d2) |
                  for (_ <- d2) {
                    TreeHashMap!("set", thm, "k", "v3", *s3) |
                    for (_ <- s3) {
                      TreeHashMap!("get", thm, "k", *getCh) |
                      rhoSpec!("assert", ("v3", "== <-", *getCh),
                        "After 3 set/delete cycles get returns the most recent value",
                        *ackCh)
                    }
                  }
                }
              }
            }
          }
        }
      } |

      // After delete, update walks the same code path as update-on-never-set.
      // With the same `val + 1` update body that yields no result on Nil
      // input, get must return Nil — matching test_get_after_update_nil.
      contract test_update_after_delete(rhoSpec, _, ackCh) = {
        new ret, setCh, delCh, updCh, getCh, update in {
          TreeHashMap!("init", 3, *ret) |
          contract update(@val, retCh) = {
            retCh!(val + 1)
          } |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "k", 50, *setCh) |
            for (_ <- setCh) {
              TreeHashMap!("delete", thm, "k", *delCh) |
              for (_ <- delCh) {
                TreeHashMap!("update", thm, "k", *update, *updCh) |
                for (_ <- updCh) {
                  TreeHashMap!("get", thm, "k", *getCh) |
                  rhoSpec!("assert", (Nil, "== <-", *getCh),
                    "Update after delete behaves like update on never-set",
                    *ackCh)
                }
              }
            }
          }
        }
      } |

      // toMap traversal must respect deletions. Existing convert_to_map_*
      // tests only exercise the set path; this one inserts three keys,
      // deletes the middle one, and asserts toMap reflects the deletion.
      contract test_to_map_after_delete(rhoSpec, _, ackCh) = {
        new ret, setACh, setBCh, setCCh, delCh, toMapCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "a", 1, *setACh) |
            TreeHashMap!("set", thm, "b", 2, *setBCh) |
            TreeHashMap!("set", thm, "c", 3, *setCCh) |
            for (_ <- setACh; _ <- setBCh; _ <- setCCh) {
              TreeHashMap!("delete", thm, "b", *delCh) |
              for (_ <- delCh) {
                TreeHashMap!("toMap", thm, *toMapCh) |
                rhoSpec!("assert", ({"a": 1, "c": 3}, "== <-", *toMapCh),
                  "toMap reflects deletion: 'b' is absent",
                  *ackCh)
              }
            }
          }
        }
      } |

      // depth=1 forces every key onto a 16-leaf root, maximizing the
      // interior-node bitmap pressure that the BitmaskOr fix is designed
      // to handle without conflict. Three sets followed by three gets
      // verifies the heavily-shared-interior case.
      contract test_treehashmap_depth_1(rhoSpec, _, ackCh) = {
        new ret, s1, s2, s3, g1, g2, g3 in {
          TreeHashMap!("init", 1, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "key1", "val1", *s1) |
            TreeHashMap!("set", thm, "key2", "val2", *s2) |
            TreeHashMap!("set", thm, "key3", "val3", *s3) |
            for (_ <- s1; _ <- s2; _ <- s3) {
              TreeHashMap!("get", thm, "key1", *g1) |
              TreeHashMap!("get", thm, "key2", *g2) |
              TreeHashMap!("get", thm, "key3", *g3) |
              rhoSpec!("assertMany",
                [
                  (("val1", "== <-", *g1), "depth=1: key1 retrievable"),
                  (("val2", "== <-", *g2), "depth=1: key2 retrievable"),
                  (("val3", "== <-", *g3), "depth=1: key3 retrievable"),
                ],
                *ackCh)
            }
          }
        }
      } |

      // getOrElse on a deleted key must return the default — covers a gap
      // relative to test_get_or_else_when_key_missing (which only covers
      // never-set keys).
      contract test_get_or_else_after_delete(rhoSpec, _, ackCh) = {
        new ret, setCh, delCh, geCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "k", "original", *setCh) |
            for (_ <- setCh) {
              TreeHashMap!("delete", thm, "k", *delCh) |
              for (_ <- delCh) {
                TreeHashMap!("getOrElse", thm, "k", "default_value", *geCh) |
                rhoSpec!("assert", ("default_value", "== <-", *geCh),
                  "getOrElse returns default value after key is deleted",
                  *ackCh)
              }
            }
          }
        }
      } |

      // Practical consequence of the no-bit-clear invariant: after wholesale
      // deletion of N keys, the interior chain still allows fresh inserts
      // anywhere. Insert 5 keys, delete all 5, insert 5 different keys,
      // assert all 5 new keys are retrievable. If delete cleared interior
      // bits along the way, the second wave of inserts could land on
      // freshly-MakeNode'd leaves with mismatched unforgeable identities,
      // breaking either the insert or a subsequent get.
      contract test_bulk_insert_then_bulk_delete_then_reinsert(rhoSpec, _, ackCh) = {
        new ret,
            sa, sb, sc, sd, se,
            da, db, dc, dd, de,
            sv, sw, sx, sy, sz,
            gv, gw, gx, gy, gz
        in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "a", "A", *sa) |
            TreeHashMap!("set", thm, "b", "B", *sb) |
            TreeHashMap!("set", thm, "c", "C", *sc) |
            TreeHashMap!("set", thm, "d", "D", *sd) |
            TreeHashMap!("set", thm, "e", "E", *se) |
            for (_ <- sa; _ <- sb; _ <- sc; _ <- sd; _ <- se) {
              TreeHashMap!("delete", thm, "a", *da) |
              TreeHashMap!("delete", thm, "b", *db) |
              TreeHashMap!("delete", thm, "c", *dc) |
              TreeHashMap!("delete", thm, "d", *dd) |
              TreeHashMap!("delete", thm, "e", *de) |
              for (_ <- da; _ <- db; _ <- dc; _ <- dd; _ <- de) {
                TreeHashMap!("set", thm, "v", "V", *sv) |
                TreeHashMap!("set", thm, "w", "W", *sw) |
                TreeHashMap!("set", thm, "x", "X", *sx) |
                TreeHashMap!("set", thm, "y", "Y", *sy) |
                TreeHashMap!("set", thm, "z", "Z", *sz) |
                for (_ <- sv; _ <- sw; _ <- sx; _ <- sy; _ <- sz) {
                  TreeHashMap!("get", thm, "v", *gv) |
                  TreeHashMap!("get", thm, "w", *gw) |
                  TreeHashMap!("get", thm, "x", *gx) |
                  TreeHashMap!("get", thm, "y", *gy) |
                  TreeHashMap!("get", thm, "z", *gz) |
                  rhoSpec!("assertMany",
                    [
                      (("V", "== <-", *gv), "v retrievable after bulk delete + reinsert"),
                      (("W", "== <-", *gw), "w retrievable after bulk delete + reinsert"),
                      (("X", "== <-", *gx), "x retrievable after bulk delete + reinsert"),
                      (("Y", "== <-", *gy), "y retrievable after bulk delete + reinsert"),
                      (("Z", "== <-", *gz), "z retrievable after bulk delete + reinsert"),
                    ],
                    *ackCh)
                }
              }
            }
          }
        }
      } |

      contract test_convert_to_map_0_values(rhoSpec, _, ackCh) = {
        new ret, insertReady, toMapCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("toMap", thm, *toMapCh) |
            rhoSpec!("assert", ({}, "== <-", *toMapCh), "toMapCh contains equal map", *ackCh)
          }
        }
      } |

      contract test_convert_to_map_1_values(rhoSpec, _, ackCh) = {
        new ret, insertReady, toMapCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key1", "some val1", *insertReady) |

            for (_ <- insertReady) {
              TreeHashMap!("toMap", thm, *toMapCh) |
              rhoSpec!(
                "assert",
                ({"some key1": "some val1"}, "== <-", *toMapCh),
                "toMapCh contains equal map",
                *ackCh
              )
            }
          }
        }
      } |

      contract test_convert_to_map_2_values(rhoSpec, _, ackCh) = {
        new ret, insertReady, toMapCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key1", "some val1", *insertReady) |
            TreeHashMap!("set", thm, "some key2", "some val2", *insertReady) |

            for (_ <- insertReady; _ <- insertReady) {
              TreeHashMap!("toMap", thm, *toMapCh) |
              rhoSpec!(
                "assert",
                ({"some key1": "some val1", "some key2": "some val2"}, "== <-", *toMapCh),
                "toMapCh contains equal map",
                *ackCh
              )
            }
          }
        }
      } |

      contract test_convert_to_map_3_values(rhoSpec, _, ackCh) = {
        new ret, insertReady, toMapCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key1", "some val1", *insertReady) |
            TreeHashMap!("set", thm, "some key2", "some val2", *insertReady) |
            TreeHashMap!("set", thm, "some key3", "some val3", *insertReady) |

            for (_ <- insertReady; _ <- insertReady; _ <- insertReady) {
              TreeHashMap!("toMap", thm, *toMapCh) |
              rhoSpec!(
                "assert",
                ({"some key1": "some val1", "some key2": "some val2", "some key3": "some val3"}, "== <-", *toMapCh),
                "toMapCh contains equal map",
                *ackCh
              )
            }
          }
        }
      } |

      contract test_convert_to_map_4_values(rhoSpec, _, ackCh) = {
        new ret, insertReady, toMapCh in {
          TreeHashMap!("init", 3, *ret) |
          for (@thm <- ret) {
            TreeHashMap!("set", thm, "some key1", "some val1", *insertReady) |
            TreeHashMap!("set", thm, "some key2", "some val2", *insertReady) |
            TreeHashMap!("set", thm, "some key3", "some val3", *insertReady) |
            TreeHashMap!("set", thm, "some key4", "some val4", *insertReady) |

            for (_ <- insertReady; _ <- insertReady; _ <- insertReady; _ <- insertReady) {
              TreeHashMap!("toMap", thm, *toMapCh) |
              rhoSpec!(
                "assert",
                ({"some key1": "some val1", "some key2": "some val2", "some key3": "some val3", "some key4": "some val4"}, "== <-", *toMapCh),
                "toMapCh contains equal map",
                *ackCh
              )
            }
          }
        }
      }
    }
  }
}