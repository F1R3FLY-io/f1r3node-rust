(*
  Isabelle session for the Rholang name garbage collection mechanization.

  Targets Isabelle 2025-2 with bundled HOL only --- the AFP entry Nominal2
  is not assumed.  Binders are handled with explicit freshness side-
  conditions; \<alpha>-equivalence at the top level is informal and discharged by
  the New rule's freshness invariant.

  Build locally with:
      isabelle build -d formal/isabelle RholangGC
*)

session RholangGC = HOL +
  description \<open>
    Mechanization of Rholang name garbage collection.  Phase 0: skeleton with
    definitions and theorem statements; soundness/non-triviality proofs are
    being discharged in Phase 1.
  \<close>
  options [document = false, quick_and_dirty]
  sessions
    "HOL-Library"
  theories
    Atoms
    Syntax
    Names
    Patterns
    RSpace
    Reduction
    FreeNames
    Garbage
    SoundnessGC0
    NonTriviality
    SoundnessGC1
    Adequacy
