# Rust
*.rs.bk

# Per-crate Cargo.lock (cargo build artifacts when invoked in subdirs)
# Only the workspace-root Cargo.lock is tracked.
Cargo.lock
!/Cargo.lock

# BNFC generated
rholang/bnfc/
rholang/src/main/java/

# Secp256k1
crypto/secp256k1/

# direnv
.direnv
.envrc

# Environment
.env
.python-version

# Docker compose data
docker/data/
docker/data.*/

# LMDB files
rholang/**/*.mdb

# proptest regression artifacts (created by proptest on test failures, used to
# replay shrunken counterexamples; safe to regenerate, not worth tracking)
**/*.proptest-regressions

# Rust JNI/JNA libraries (legacy hybrid build)
rust_libraries/**

# Run-local node data
run-local/data/

# Logs
*.log

# Aider
.aider*

# OCI testbed state (EPOCH-009)
scripts/remote/testbed-state.json
scripts/remote/testbed.pem
scripts/remote/testbed.pem.pub

# story-manager.sh backup artifacts
docs/*.md.bak
.claude/
